    {
      "parameters": {
        "jsCode": "// Leemos el archivo binario de S3\nconst binaryData = await this.helpers.getBinaryDataBuffer(0, 'data');\nconst jsonString = binaryData.toString('utf-8');\nconst cartelera = JSON.parse(jsonString);\n\n// Pasamos toda la cartelera junta en la propiedad \"cartelera\"\nreturn [{ json: { cartelera: cartelera } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        340,
        0
      ],
      "id": "8e7fd6f9-a7d4-41de-8ce3-138ddee98601",
      "name": "Code in JavaScript"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.groq.com/openai/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.GROQ_API_KEY }}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"llama-3.1-8b-instant\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"Tu trabajo es clasificar el mensaje de un usuario sobre cine en una de dos opciones: 'chat' o 'soundtrack'. Si el usuario pide crear, generar o escuchar una banda sonora, canción, melodía o soundtrack de una película de la cartelera, responde 'soundtrack'. Para todo lo demás (preguntas, sinopsis, recomendaciones o saludos), responde 'chat'. Responde ÚNICAMENTE con la palabra 'chat' o 'soundtrack' sin explicaciones ni formato adicional.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": {{ JSON.stringify($('Webhook').first().json.body.message.text) }}\n    }\n  ]\n}",
        "options": {}
      },
      "id": "intent-classifier",
      "name": "Clasificador de Intención",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        500,
        0
      ]
    },
    {
      "parameters": {
        "dataType": "string",
        "value1": "={{ $json.choices[0].message.content.trim().toLowerCase() }}",
        "rules": {
          "rules": [
            {
              "value2": "soundtrack",
              "output": 0
            },
            {
              "value2": "chat",
              "output": 1
            }
          ]
        }
      },
      "id": "switch-router",
      "name": "Enrutador de Consultas",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 2,
      "position": [
        680,
        0
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.groq.com/openai/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.GROQ_API_KEY }}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ model: \"llama-3.1-8b-instant\", messages: [{ role: \"system\", content: \"Eres un simpático acomodador de cine. Responde de forma muy amigable basándote en la cartelera que te pasamos.\" }, { role: \"user\", content: \"PREGUNTA: \" + $('Webhook').first().json.body.message.text + \"\\n\\nCARTELERA: \" + JSON.stringify($('Code in JavaScript').first().json.cartelera) }] }) }}",
        "options": {}
      },
      "id": "f1950b9a-b424-447e-928e-e0800ee9873e",
      "name": "Chat Acomodador",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        860,
        -100
      ]
    },
    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\nlet respuesta = \"Lo siento, he tenido un problema procesando tu pregunta.\";\n\nif (data && data.choices && data.choices.length > 0) {\n  respuesta = data.choices[0].message.content;\n}\n\nreturn [{ \n  json: { \n    mensaje: respuesta, \n    chat_id: $('Webhook').first().json.body.message.chat.id \n  } \n}];"
      },
      "id": "91f3b703-bd5f-423c-a9f0-4a6b442bb572",
      "name": "Extraer Respuesta Chat",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1040,
        -100
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://api.telegram.org/bot{{ $env.BOT_TOKEN }}/sendMessage",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{\n{\n  \"chat_id\": $json.chat_id,\n  \"text\": $json.mensaje,\n  \"parse_mode\": \"Markdown\"\n}\n}}",
        "options": {}
      },
      "id": "c2099675-b4e0-4c44-bd18-9e963c9d03a1",
      "name": "Enviar Respuesta Telegram",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        1220,
        -100
