    {
      "parameters": {
        "method": "POST",
        "url": "https://api.groq.com/openai/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.GROQ_API_KEY }}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"llama-3.1-8b-instant\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"Eres un compositor experto de bandas sonoras. El usuario quiere generar un tema musical para una película de la cartelera. Basándote en la cartelera que te pasamos, busca la película que indica el usuario y genera un JSON con dos campos:\\n- 'pelicula': El título de la película.\\n- 'style': Un prompt musical descriptivo de 6 a 10 palabras (ej: 'sci-fi electronic synthwave, dramatic brass, hans zimmer style' o 'melancholic piano, soft violin, emotional orchestral').\\nResponde ÚNICAMENTE con el objeto JSON válido, sin explicaciones ni markdown.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": {{ JSON.stringify(\"PREGUNTA: \" + $('Webhook').first().json.body.message.text + \"\\n\\nCARTELERA: \" + JSON.stringify($('Code in JavaScript').first().json.cartelera)) }}\n    }\n  ]\n}",
        "options": {}
      },
      "id": "bso-composer",
      "name": "Generar Prompt Musical",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        860,
        150
      ]
    },
    {
      "parameters": {
        "jsCode": "const responseText = $input.first().json.choices[0].message.content;\nlet result = { pelicula: \"Película\", style: \"ambient, electronic\" };\n\ntry {\n  const cleaned = responseText.replace(/```json/g, \"\").replace(/```/g, \"\").trim();\n  const parsed = JSON.parse(cleaned);\n  if (parsed.pelicula) result.pelicula = parsed.pelicula;\n  if (parsed.style) result.style = parsed.style;\n} catch (e) {\n  result.style = responseText;\n}\n\nreturn [{ \n  json: { \n    pelicula: result.pelicula, \n    style: result.style,\n    caption: `🎵 *Banda Sonora de la Película* 🎬\\n\\n🎥 *Película:* ${result.pelicula}\\n🎹 *Estilo:* ${result.style}\\n\\n*Nota:* Ejecutado en modo de CPU de bajo consumo (Resiliente). ¡Aquí tienes tu melodía de muestra sintetizada en MinIO! ⚡`\n  } \n}];"
      },
      "id": "parse-prompt",
      "name": "Parsear BSO Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1020,
        150
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://comfyui:8188/prompt",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"client_id\": \"n8n_client\",\n  \"prompt\": {\n    \"1\": {\n      \"inputs\": {\n        \"text\": \"{{ $json.style }}\"\n      },\n      \"class_type\": \"CLIPTextEncode\"\n    },\n    \"2\": {\n      \"inputs\": {\n        \"filename_prefix\": \"n8n_soundtrack\",\n        \"audio\": [\"3\", 0]\n      },\n      \"class_type\": \"SaveAudio\"\n    },\n    \"3\": {\n      \"inputs\": {\n        \"text\": \"{{ $json.style }}\",\n        \"duration\": 10\n      },\n      \"class_type\": \"ACE-Step-Generator\"\n    }\n  }\n}",
        "options": {
          "neverThrowError": true
        }
      },
