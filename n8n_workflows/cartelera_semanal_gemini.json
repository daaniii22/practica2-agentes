{
  "name": "Cartelera Semanal + Guardarra\u00edl",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "weeks",
              "triggerAtDay": [
                1
              ],
              "triggerAtHour": 9
            }
          ]
        }
      },
      "id": "a1b2c3d4-1111-4aaa-aaaa-111111111111",
      "name": "Cada Lunes 9:00",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        0,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://scrapper:8000/cartelera",
        "sendBody": true,
        "bodyParameters": {
          "parameters": []
        },
        "options": {
          "timeout": 300000
        }
      },
      "id": "a1b2c3d4-2222-4bbb-bbbb-222222222222",
      "name": "Obtener Cartelera",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        250,
        300
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "cond-1",
              "leftValue": "={{ $json.total }}",
              "rightValue": 0,
              "operator": {
                "type": "number",
                "operation": "gt"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "a1b2c3d4-3333-4ccc-cccc-333333333333",
      "name": "\u00bfHay pel\u00edculas?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        500,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "// Formateamos toda la cartelera en un único mensaje gigante para Gemini\nconst peliculas = $input.first().json.peliculas;\nlet lineas = [];\n\nlineas.push(`🎬 *Cartelera de Madrid — Esta semana*\\n`);\n\nfor (const p of peliculas) {\n  lineas.push(\n    `*${p.titulo}*\\n` +\n    `  🎭 Género: ${p.genero}\\n` +\n    `  ⭐ Nota: ${p.nota}/10 (${p.votos} votos)\\n` +\n    `  🎬 Director: ${p.director}\\n` +\n    `  ⏱️ Duración: ${p.duracion}\\n` +\n    `  📝 ${p.sinopsis}\\n`\n  );\n}\n\nreturn [{ json: { mensaje: lineas.join('\\n\\n') } }];"
      },
      "id": "a1b2c3d4-4444-4ddd-dddd-444444444444",
      "name": "Formatear Mensaje",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        750,
        200
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent?key={{$env.GEMINI_API_KEY}}",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"system_instruction\": {\n    \"parts\": [\n      {\n        \"text\": \"Eres un guardarra\u00edl de contenido. Tu trabajo es revisar un mensaje con recomendaciones de pel\u00edculas que se va a enviar a usuarios por Telegram. Debes verificar que: 1) No contiene spoilers evidentes en las sinopsis, 2) El tono es profesional y amigable, 3) La informaci\u00f3n est\u00e1 bien estructurada y es legible. Si todo est\u00e1 correcto, devuelve el mensaje tal cual. Responde SOLO con el mensaje final corregido, sin explicaciones ni comentarios adicionales. Mant\u00e9n el formato Markdown con emojis.\"\n      }\n    ]\n  },\n  \"contents\": [\n    {\n      \"parts\": [\n        {\n          \"text\": {{ JSON.stringify($json.mensaje) }}\n        }\n      ]\n    }\n  ]\n}",
        "options": {
          "timeout": 120000
        },
        "authentication": "none"
      },
      "id": "a1b2c3d4-5555-4eee-eeee-555555555555",
      "name": "Google Gemini",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1000,
        200
      ]
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first();\nlet textoCompleto;\n\ntry {\n  const data = item.json;\n  if (data && data.candidates && data.candidates.length > 0) {\n    textoCompleto = data.candidates[0].content.parts[0].text;\n  } else {\n    return [{ json: { mensaje: \"Error extrayendo datos de Gemini.\" } }];\n  }\n} catch (e) {\n  return [{ json: { mensaje: \"Error procesando la respuesta de Gemini.\" } }];\n}\n\n// Dividimos el texto en trozos de máximo 4000 caracteres para Telegram\nconst MAX_LENGTH = 4000;\nconst trozos = [];\nlet posicion = 0;\n\nwhile (posicion < textoCompleto.length) {\n  let fin = posicion + MAX_LENGTH;\n  if (fin < textoCompleto.length) {\n    // Buscamos el último salto de línea para no cortar una película a la mitad\n    const ultimoSalto = textoCompleto.lastIndexOf('\\n', fin);\n    if (ultimoSalto > posicion) {\n      fin = ultimoSalto;\n    }\n  }\n  \n  trozos.push({ json: { mensaje: textoCompleto.substring(posicion, fin).trim() } });\n  posicion = fin;\n}\n\nreturn trozos;"
      },
      "id": "a1b2c3d4-6666-4fff-ffff-666666666666",
      "name": "Extraer Respuesta Guardarra\u00edl",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1250,
